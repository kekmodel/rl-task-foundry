# Copy this file to .env and fill in only the providers/databases you use.
# Never commit real API keys, access tokens, passwords, or private dataset paths.

# LLM provider keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_API_KEY=
ANTHROPIC_API_KEY=

# Optional local OpenAI-compatible endpoint
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=

# Optional database overrides. Defaults are already present in the YAML configs.
# DATABASE_DSN=postgresql://pagila:pagila@127.0.0.1:5433/pagila
# MIMIC_IV_DATABASE_DSN=postgresql://mimiciv:mimiciv@127.0.0.1:5435/mimiciv
# MIMIC_IV_DEMO_DATABASE_DSN=postgresql://mimiciv_demo:mimiciv_demo@127.0.0.1:5436/mimiciv_demo

# Optional PhysioNet credentials for full MIMIC-IV bootstrap.
PHYSIONET_USERNAME=
PHYSIONET_PASSWORD=

# Optional local MIMIC-IV data/cache controls.
# MIMIC_IV_DATA_DIR=/path/to/mimiciv/3.1
# MIMIC_IV_AUTO_DOWNLOAD=1
